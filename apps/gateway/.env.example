# apps/gateway environment — copy this file to `.env` and fill in your values.
#
#   cp apps/gateway/.env.example apps/gateway/.env
#
# These are read server-side only (by the /api/chat route) and are NEVER sent to the browser.
#
# Precedence: this `.env` is a FALLBACK. `pnpm dev` loads it only for keys that are not already in
# process.env, so anything injected by Doppler (or a shell export) wins. `vite.config.ts` keeps the
# same fallback behavior when running `pnpm gateway:dev` directly. Using Doppler for local dev? You can
# skip this file entirely — see apps/gateway/README.md.

# Model provider API keys. Provide whichever providers you plan to use. These are operator-managed
# fallbacks: a workspace admin-saved provider key in Gateway takes precedence when configured.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Required before admins can save workspace provider keys in Gateway. Keep this outside the database;
# DB backups contain encrypted provider keys and need this secret to decrypt them.
# Generate with: openssl rand -base64 32
FICTA_GATEWAY_KEY_ENCRYPTION_SECRET=

# The ficta redaction proxy that model calls are routed through (must be running).
# Defaults to the proxy's local address if unset.
FICTA_PROXY_URL=http://127.0.0.1:8787

# PDF/DOCX attachment conversion. In this source checkout, root `pnpm dev` starts/reuses the local
# Docker sidecar by default; outside `pnpm dev` use `pnpm sidecars` or run the converter yourself.
# FICTA_DOC_CONVERTER_URL=http://127.0.0.1:5003
# FICTA_DOC_CONVERTER_BACKEND=markitdown
# FICTA_DOC_CONVERTER_MANAGED=1

# Optional PII protection through managed local analyzer sidecars (Presidio, OpenMed).
# In this source checkout, root `pnpm dev` starts Docker automatically for backends selected via
# FICTA_PII_BACKENDS / FICTA_PII_BACKEND; outside `pnpm dev` use `pnpm sidecars` (repo-root
# docker-compose.sidecars.yml). The mounted Presidio registry enables South African ID numbers and
# company registration numbers.
# FICTA_PII_ENABLED=1
# FICTA_PII_BACKEND=presidio
# # Or select multiple native backends:
# # FICTA_PII_BACKENDS=presidio,openmed
# FICTA_PII_PRESIDIO_URL=http://127.0.0.1:5002
# FICTA_PII_OPENMED_URL=http://127.0.0.1:5004
# FICTA_PII_PRESIDIO_MANAGED=1
# FICTA_PII_OPENMED_MANAGED=1

# --- Auth ------------------------------------------------------------------------------------------
# Which auth provider gates the app. `none` (default) = fully open, self-hosted; no WorkOS SDK is
# loaded at runtime and the app behaves exactly as it does without auth. `workos` = hosted AuthKit.
AUTH_PROVIDER=none

# Only needed when AUTH_PROVIDER=workos. From the WorkOS dashboard; the redirect URI must be registered
# there and match this value. Generate the cookie password with: openssl rand -base64 24 (32+ chars).
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=
WORKOS_COOKIE_PASSWORD=

# Note: vite.config.ts loads this .env into the server process for `vite dev`/`vite build` only.
# In production (`node .output/server/index.mjs`) supply these via real shell/Doppler env.

# --- Storage ---------------------------------------------------------------------------------------
# Where settings + chat history live. There is one schema (Postgres dialect) and two drivers:
#
#   default (nothing set) : embedded, file-backed PGlite — zero external services. Great for
#                           self-hosted single-process installs. Data goes under FICTA_GATEWAY_DATA_DIR.
#   DATABASE_URL set      : real Postgres via node-postgres. REQUIRED for multi-process/serverless
#                           deployments (PGlite is single-connection, one instance per data dir).
#
# Behavior matrix: none-auth + PGlite is the works-out-of-the-box default; workos + Postgres is the
# hosted setup. Migrations are bundled into the server build and applied automatically on first use.
DATABASE_URL=
# Directory for the embedded PGlite database when DATABASE_URL is unset. Relative to the app's cwd.
FICTA_GATEWAY_DATA_DIR=.data/pglite
