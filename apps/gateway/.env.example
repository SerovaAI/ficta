# Ficta Gateway deployment environment.
#
# For an isolated local POC, copy this file to `.env` and set one provider key. Proxy protection
# policy belongs in ~/.ficta/config.toml; use packages/ficta/docs/poc-configuration.md as the
# canonical POC policy. Shell/Doppler values take precedence over this file. Do not commit secrets.

# Provider fallback keys. Admin-saved workspace keys take precedence when configured.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional issue reporting. Create a Linear personal API key with only "Create issues"
# permission, restrict it to the destination team, and set that team's UUID here. The report icon is
# hidden unless both values are present. Build id is optional safe diagnostic metadata.
# FICTA_GATEWAY_LINEAR_API_KEY=lin_api_...
# FICTA_GATEWAY_LINEAR_TEAM_ID=00000000-0000-0000-0000-000000000000
# FICTA_GATEWAY_BUILD_ID=git-sha-or-release-id

# Required only when admins save workspace provider keys in Gateway.
# Generate with: openssl rand -base64 32
FICTA_GATEWAY_KEY_ENCRYPTION_SECRET=

# Optional local/deployment wiring. The defaults work when Gateway, proxy, and sidecars share the
# same host and working directory.
# FICTA_PROXY_URL=http://127.0.0.1:8787
# FICTA_DOC_CONVERTER_URL=http://127.0.0.1:5003
# FICTA_GATEWAY_DATA_DIR=.data/pglite
# FICTA_GATEWAY_MANAGED_REGISTRY_PATH=/var/lib/ficta/protected-registry.json

# Hosted/multi-user deployments only. `none` is suitable only for local or otherwise isolated POCs.
AUTH_PROVIDER=none
# FICTA_GATEWAY_ORG_ID=org_...
# WORKOS_CLIENT_ID=
# WORKOS_API_KEY=
# WORKOS_REDIRECT_URI=https://gateway.example.com/api/auth/callback
# WORKOS_COOKIE_PASSWORD=

# Set for shared/multi-process Postgres. Unset uses embedded single-process PGlite.
# DATABASE_URL=postgres://...
