# Optional one-off shell environment overrides.
# Prefer `ficta setup` for persistent ~/.ficta/config.toml settings.
# Do not commit real secrets.

# Common overrides
# FICTA_CONFIG_FILE=~/.ficta/config.toml
# FICTA_REQUIRE_REGISTRY=1
# FICTA_REDACT_PATHS=1
# FICTA_LOG_MAX_BYTES=262144

# Registry sources
# FICTA_REGISTRY_ENV_FILE_ENABLED=1
# FICTA_REGISTRY_ENV_FILE_PATHS=.env:.env.local
# FICTA_REGISTRY_MANAGED_FILE_ENABLED=1
# FICTA_REGISTRY_MANAGED_FILE_PATHS=.data/protected-registry.json
# FICTA_REGISTRY_DOPPLER_ENABLED=1
# FICTA_REGISTRY_DOPPLER_CONFIGS=current
# FICTA_REGISTRY_DOPPLER_PROJECT=
# FICTA_REGISTRY_DOPPLER_COMMAND=doppler
# FICTA_REGISTRY_PROCESS_ENV_ENABLED=1
# FICTA_REGISTRY_PROCESS_ENV_MODE=secret-ish
# FICTA_REGISTRY_MIN_LEN=8

# Runtime / diagnostics
# FICTA_PORT=8787
# FICTA_LOG_DIR=~/.ficta/logs   # full override of the exact capture-log path (all roles)
# FICTA_LOG_ROOT=~/.ficta/logs  # log root only; the server writes under gateway/, each
#                               # `ficta <agent>` shim under agents/<agent>/<instance>/
# FICTA_LOG_LEVEL=info   # silent|error|warn|info|debug|trace (structured log verbosity only)
# FICTA_PRESERVE_LITERALS=1 # ask the model to reproduce minted surrogate tokens exactly
# FICTA_FAIL_CLOSED=1
# FICTA_ANTHROPIC_UPSTREAM=https://api.anthropic.com
# FICTA_OPENAI_UPSTREAM=https://api.openai.com
# FICTA_CHATGPT_UPSTREAM=https://chatgpt.com
# FICTA_ALLOW_CUSTOM_UPSTREAM=0

# Request-time detector layers
# FICTA_SECRET_SHAPES_ENABLED=1
# FICTA_PII_ENABLED=1
# FICTA_PII_BACKEND=presidio
# # Or select multiple native backends:
# # FICTA_PII_BACKENDS=presidio,openmed
# FICTA_PII_PRESIDIO_URL=http://127.0.0.1:5002
# FICTA_PII_OPENMED_URL=http://127.0.0.1:5004
# Source-checkout `pnpm dev` only: start/reuse the Docker sidecars for the selected backends
# (FICTA_PII_BACKENDS / FICTA_PII_BACKEND). The flags below force it on/off per sidecar; outside
# `pnpm dev` use `pnpm sidecars` (docker-compose.sidecars.yml) or run the containers yourself.
# FICTA_PII_PRESIDIO_MANAGED=1
# FICTA_PII_PRESIDIO_NLP_CONFIG_FILE=packages/ficta/presidio/nlp_engine.za.yaml
# FICTA_PII_OPENMED_MANAGED=1
# Pin a tag or point at a locally built (patched) image instead of upstream's published one.
# FICTA_PII_OPENMED_IMAGE=ghcr.io/maziyarpanahi/openmed:latest
# FICTA_PII_OPENMED_STARTUP_TIMEOUT_MS=300000
