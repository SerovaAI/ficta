# Optional local ficta config example.
# `ficta setup` writes ~/.ficta/config.toml. Shell environment variables override this file.
# Do not commit real secrets or your surrogate key.

[registry]
min_len = 8
require = false
# Exact env var names to leave unprotected after review, e.g. ["LOG_LEVEL"].
exclude_names = []

[registry.env_file]
enabled = true
paths = [".env", ".env.local"]

[registry.managed_file]
enabled = true
paths = [".data/protected-registry.json"]

[registry.process_env]
enabled = true
mode = "secret-ish" # or "all"

[registry.doppler]
enabled = true
configs = "current" # or "all" / ["dev", "prod"]
project = ""
# Trusted local executable only; ficta refuses project-local/world-writable commands
# and runs Doppler with a minimal Doppler/HOME/proxy env.
# command = "doppler"
timeout_ms = 5000

[redaction]
# Registered exact-secret leaks fail closed by default.
fail_closed = true
redact_paths = false
# Restore locally-read detected content into tool-call arguments while keeping registry secrets as
# placeholders. Alternatives: "all" restores every value; "none" restores no values into tools.
restore_into_tools = "detected"

[detection]
# Detector-backend outages default to fail-open (skip detection and forward).
# This is separate from redaction.fail_closed, which covers registered exact-secret leaks.
fail_closed = false

[secret_shapes]
# Web / standalone proxy request-time detection for newly pasted token shapes not present in the
# launch-time registry: API keys, JWTs, private keys, credential URLs, and secret-ish assignments.
# `ficta setup` prompts for this and defaults it on; an unconfigured proxy remains off.
enabled = true
# Coding-agent launches stay off unless this is also true (or FICTA_SECRET_SHAPES_ENABLED is set for one run).
agents = false
[pii]
# Web / standalone proxy PII detection. `ficta setup` prompts for this and defaults it on;
# an unconfigured proxy remains off.
enabled = true
# Coding-agent launches stay off unless this is also true (or FICTA_PII_ENABLED is set for one run).
agents = false
# One or more backends can run. `backend` is the legacy single-backend setting; `backends`
# takes precedence when set.
backend = "regex"
# backends = ["presidio", "openmed"]
# PII-specific detector-outage policy; overrides [detection] fail_closed.
fail_closed = false

[pii.presidio]
# Used when [pii] backend/backends includes "presidio". Presidio is a first-class supported backend,
# backed by a presidio-analyzer sidecar. The source-checkout `pnpm dev` wrapper can manage a local
# Docker sidecar; installed/runtime deployments should run the analyzer sidecar explicitly.
url = "http://127.0.0.1:5002"
language = "en"
score_threshold = 0.5
entities = [] # empty = all entities returned by Presidio
# Total detection budget per request.
timeout_ms = 1500

[pii.openmed]
# Used when [pii] backends includes "openmed". Run the upstream OpenMed REST service (its own
# Docker image, unmodified) separately from Presidio and point Ficta at it.
url = "http://127.0.0.1:5004"
# Model repo id sent as model_name; empty = the server's default PII model.
model = ""
lang = "en"
score_threshold = 0.5
entities = [] # empty = all labels; otherwise a canonical-label allowlist applied client-side
# Total detection budget per request (transformer inference is slower than Presidio's rules).
timeout_ms = 2500

[logging]
# Raw body logging uses the ephemeral runtime admin control; it is never persisted here.
max_bytes = 262144
# Root for per-role subtrees (`gateway/` and `agents/<agent>/<instance>/`).
log_root = "~/.ficta/logs"
# Full path override that bypasses the per-role split:
# log_dir = "/custom/exact/log/path"

# Generated by `ficta setup` / `ficta install` when absent.
# [surrogate]
# key = "..."
# Token style: "opaque" (default) mints FICTA_<hex>; "typed" mints FICTA_<TYPE>_<hex>
# (FICTA_PERSON_…, FICTA_SSN_…) so the model keeps a grammatical cue for the redacted span —
# reversibility and determinism are unchanged. Also settable via FICTA_SURROGATE_STYLE.
# style = "opaque"

# Runtime / diagnostics
# [runtime]
# port = 8787
#
# [upstreams]
# anthropic = "https://api.anthropic.com"
# openai = "https://api.openai.com"
# chatgpt = "https://chatgpt.com"
# forced = "http://127.0.0.1:9000"
# allow_custom = false # set true only for trusted non-default HTTPS upstreams
