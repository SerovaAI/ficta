{
  "name": "@serovaai/ficta",
  "version": "0.2.1",
  "private": false,
  "type": "module",
  "description": "Keep your registered secrets out of the LLM — local redaction proxy for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SerovaAI/ficta.git",
    "directory": "packages/ficta"
  },
  "bugs": {
    "url": "https://github.com/SerovaAI/ficta/issues"
  },
  "homepage": "https://ficta.sh",
  "keywords": [
    "ai",
    "coding-agents",
    "llm",
    "privacy",
    "redaction",
    "secrets"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ficta": "bin/ficta.mjs"
  },
  "exports": {
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "presidio/",
    "config.toml.example",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "start": "tsx src/server.ts",
    "ficta": "tsx src/cli.ts",
    "build": "tsc",
    "check:presidio": "tsx scripts/verify-presidio-sidecar.mts",
    "prepack": "pnpm build",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "pnpm check:static && pnpm typecheck && pnpm test",
    "check:static": "node scripts/check-engine-boundary.mjs && biome check .",
    "check:fix": "biome check --write .",
    "update": "pnpm up -r -i -L",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "check:live": "pnpm check && pnpm test:e2e",
    "bench": "tsx bench/redaction-bench.mts",
    "bench:entity": "tsx bench/entity-redaction-bench.mts",
    "bench:entity-fidelity": "tsx bench/entity-surrogate-fidelity.mts",
    "check:entity-fidelity-live": "tsx bench/entity-surrogate-fidelity.mts --live-matrix",
    "bench:pii-ner": "tsx bench/pii-ner-benchmark.mts",
    "bench:e2e": "tsx bench/e2e-bench.mts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@hono/node-server": "^2.0.10",
    "@serovaai/ficta-protocol": "workspace:^",
    "hono": "^4.12.30",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
