{
  "name": "@serovaai/ficta",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "Keep your registered secrets out of the LLM — local redaction proxy for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SerovaAI/ficta.git",
    "directory": "packages/ficta"
  },
  "bugs": {
    "url": "https://github.com/SerovaAI/ficta/issues"
  },
  "homepage": "https://ficta.sh",
  "keywords": [
    "ai",
    "coding-agents",
    "llm",
    "privacy",
    "redaction",
    "secrets"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ficta": "bin/ficta.mjs"
  },
  "exports": {
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "presidio/",
    "config.toml.example",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "start": "tsx src/server.ts",
    "ficta": "tsx src/cli.ts",
    "build": "tsc",
    "verify": "pnpm check && pnpm typecheck && pnpm test",
    "prepack": "pnpm build",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "node scripts/check-engine-boundary.mjs && biome check .",
    "check:fix": "biome check --write .",
    "update": "pnpm up -r -i -L",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "verify:live": "pnpm verify && pnpm test:e2e",
    "bench": "tsx bench/redaction-bench.mts",
    "bench:e2e": "tsx bench/e2e-bench.mts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@hono/node-server": "^2.0.6",
    "@serovaai/ficta-protocol": "workspace:^",
    "hono": "^4.12.28",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
