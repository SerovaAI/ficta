{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": [
    "doppler"
  ],
  "ignoreExportsUsedInFile": true,
  "tags": [
    "-lintignore"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/dev-runner.mjs",
        "scripts/gateway-dev.mjs"
      ],
      "project": [
        "scripts/**/*.mjs"
      ]
    },
    "apps/gateway": {
      "entry": [
        "src/router.tsx",
        "src/start.ts",
        "src/routes/**/*.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "src/**/*.css",
        "test/**/*.ts"
      ]
    },
    "apps/web": {
      "entry": [
        "src/router.tsx",
        "src/routes/**/*.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "src/**/*.css"
      ]
    },
    "packages/ficta": {
      "entry": [
        "bench/*.mts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts",
        "bench/**/*.mts",
        "*.config.ts"
      ]
    },
    "packages/protocol": {
      "project": [
        "src/**/*.d.ts"
      ]
    }
  }
}
