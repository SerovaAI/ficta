# Ficta proxy environment — installed to /etc/ficta/proxy.env (chmod 640, group ficta).
# Protection POLICY does not belong here: it lives in ~ficta/.ficta/config.toml
# (deploy/ficta-config.toml). Environment is for deployment wiring only.

# Listen port (default 8787, loopback service consumed by the Gateway)
# FICTA_PORT=8787

# Managed registry file published by the Gateway (same path as
# FICTA_GATEWAY_MANAGED_REGISTRY_PATH in gateway.env)
FICTA_REGISTRY_MANAGED_FILE_PATHS=/var/lib/ficta/protected-registry.json
